      font-size: var(--fs-lg);
    }
  }

  /* =========================================
     BODY LAYOUT
     ========================================= */
  .guide-body {
    padding-block: var(--space-12);
  }

  .guide-body .container {
    max-width: var(--max-width-prose);
  }

  /* =========================================
     INTRO BOX
     ========================================= */
  .guide-intro-box {
    padding: var(--space-6);
    background-color: var(--accent-bg);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: var(--radius-md);
