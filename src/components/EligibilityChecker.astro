<script>
  import { evaluateEligibility } from '../lib/eligibility.js';

  type Airport = {
    icao: string;
    iata: string;
    name: string;
    city: string;
    country: string;
    lat: number;
    lon: number;
    iataLc: string;
    nameLc: string;
    cityLc: string;
  };

  type Airline = {
    iata: string;
    icao: string;
    name: string;
    country: string;
    iataLc: string;
    nameLc: string;
  };

  type IssueType = 'delayed' | 'cancelled' | 'denied_boarding' | 'downgraded';
  type DelayDuration = 'under_2h' | '2_to_3h' | '3_to_4h' | '4h_plus' | 'never_arrived';
  type NotificationTiming = 'under_7d' | '7_to_13d' | '14d_plus' | 'at_airport' | 'unknown';
  type ReroutingOffered = 'yes_accepted' | 'yes_declined' | 'not_offered';
  type DeniedBoardingType = 'involuntary' | 'voluntary';
  type CabinClass = 'first' | 'business' | 'premium_economy' | 'economy';
  type DisruptionReason = 'weather' | 'technical' | 'strike' | 'operational' | 'security_atc' | 'unknown';

  type CoverageEntry = {
    regulation: string;
    applicable: boolean;
    compensation: null | {
      type: string;
      amount?: number;
      currency?: string;
      min?: number;
      max?: number;
      value?: number;
      basis?: string;
      description?: string;
      approxUSD?: number;
      typicalCourt?: string;
    };
    reasoning: string;
  };

  type EligibilityResult = {
    eligible: boolean;
    distance: number;
    coverage: CoverageEntry[];
    notCoveredBy: CoverageEntry[];
    outOfScope: boolean;
    outOfScopeReason: string | null;
    notes: string[];
  };

  type Selections = {
    origin: Airport | null;
    destination: Airport | null;
    airline: Airline | null;
    flightDate: string | null; // YYYY-MM-DD
    issueType: IssueType | null;
    delayDuration: DelayDuration | null;
    notificationTiming: NotificationTiming | null;
    reroutingOffered: ReroutingOffered | null;
    deniedBoardingType: DeniedBoardingType | null;
    originalClass: CabinClass | null;
    actualClass: CabinClass | null;
    disruptionReason: DisruptionReason | null;
    result: EligibilityResult | null;
  };

  // Higher index = lower class. Used to hide actual-class options that are not lower than the original class.
  const CABIN_CLASS_ORDER: CabinClass[] = ['first', 'business', 'premium_economy', 'economy'];

  const MIN_CHARS = 2;
  const MAX_RESULTS = 8;
  const TOTAL_STEPS = 6;
  const LAST_IMPLEMENTED_STEP = 6;

  const root = document.getElementById('eligibility-checker');
  if (!root) {
    console.warn('[EligibilityChecker] root not found');
  } else {
    init(root);
  }

  function init(root: HTMLElement) {
    const state: Selections = {
      origin: null,
      destination: null,
      airline: null,
      flightDate: null,
      issueType: null,
      delayDuration: null,
      notificationTiming: null,
      reroutingOffered: null,
      deniedBoardingType: null,
      originalClass: null,
      actualClass: null,
      disruptionReason: null,
      result: null,
    };
    let currentStep: number | 'result' = 1;

    // ---------- Data loaders (lazy, cached promise) ----------
    let airportsPromise: Promise<Airport[]> | null = null;
    let airlinesPromise: Promise<Airline[]> | null = null;

    const loadAirports = (): Promise<Airport[]> => {
      if (airportsPromise) return airportsPromise;
      airportsPromise = import('../data/airports.json').then((mod) => {
        const raw = mod.default as Record<string, Omit<Airport, 'iataLc' | 'nameLc' | 'cityLc'> & { lat: number; lon: number }>;
        const list: Airport[] = [];
        for (const code in raw) {
          const a = raw[code];
          if (!a.iata || a.iata.length !== 3) continue;
          list.push({
            icao: a.icao,
            iata: a.iata,
            name: a.name,
            city: a.city,
            country: a.country,
            lat: a.lat,
            lon: a.lon,
            iataLc: a.iata.toLowerCase(),
            nameLc: (a.name || '').toLowerCase(),
            cityLc: (a.city || '').toLowerCase(),
          });
        }
        return list;
      });
      return airportsPromise;
    };

    const loadAirlines = (): Promise<Airline[]> => {
      if (airlinesPromise) return airlinesPromise;
      airlinesPromise = import('../data/airlines.json').then((mod) => {
        const raw = mod.default as Array<Omit<Airline, 'iataLc' | 'nameLc'>>;
        return raw.map((a) => ({
          iata: a.iata,
          icao: a.icao || '',
          name: a.name,
          country: a.country || '',
          iataLc: a.iata.toLowerCase(),
          nameLc: a.name.toLowerCase(),
        }));
      });
      return airlinesPromise;
    };

    // ---------- Country display ----------
    let regionNames: Intl.DisplayNames | null = null;
    try {
      regionNames = new Intl.DisplayNames(['en'], { type: 'region' });
    } catch {
      regionNames = null;
    }
    const countryDisplay = (codeOrName: string) => {
      if (!codeOrName) return '';
      // ISO-2 airport country codes → display name. Airline countries are already full names.
      if (codeOrName.length === 2 && codeOrName === codeOrName.toUpperCase()) {
        try {
          return regionNames?.of(codeOrName) ?? codeOrName;
        } catch {
          return codeOrName;
        }
      }
      return codeOrName;
    };

    // ---------- Search (shared shape) ----------
    type Searchable = { iataLc: string; nameLc: string; cityLc?: string };
    function searchItems<T extends Searchable>(items: T[], query: string): T[] {
      const q = query.trim().toLowerCase();
      if (q.length < MIN_CHARS) return [];
      const results: T[] = [];
      const seen = new Set<string>();
      const push = (it: T) => {
        const key = it.iataLc + '|' + it.nameLc;
        if (seen.has(key)) return false;
        seen.add(key);
        results.push(it);
        return results.length >= MAX_RESULTS;
      };
      for (const it of items) { // tier 1: exact IATA
        if (it.iataLc === q) { if (push(it)) return results; }
      }
      if (q.length <= 3) { // tier 2: IATA starts-with
        for (const it of items) {
          if (it.iataLc.startsWith(q)) { if (push(it)) return results; }
        }
      }
      for (const it of items) { // tier 3: name or city starts-with
        if (it.nameLc.startsWith(q) || (it.cityLc && it.cityLc.startsWith(q))) {
          if (push(it)) return results;
        }
      }
      for (const it of items) { // tier 4: name or city contains
        if (it.nameLc.includes(q) || (it.cityLc && it.cityLc.includes(q))) {
          if (push(it)) return results;
        }
      }
      return results;
    }

    // ---------- Generic autocomplete ----------
    type AcConfig<T extends Searchable> = {
      wrap: HTMLElement;
      loader: () => Promise<T[]>;
      formatSelected: (item: T) => string;
      renderOption: (item: T) => string;
      onSelect: (item: T) => void;
      onClear: () => void;
    };

    function wireAutocomplete<T extends Searchable>(cfg: AcConfig<T>) {
      const input = cfg.wrap.querySelector<HTMLInputElement>('.ec-ac-input')!;
      const listbox = cfg.wrap.querySelector<HTMLUListElement>('.ec-ac-list')!;
      const clearBtn = cfg.wrap.querySelector<HTMLButtonElement>('.ec-ac-clear')!;
      const listboxId = listbox.id;
      let currentResults: T[] = [];
      let activeIndex = -1;

      const closeList = () => {
        listbox.hidden = true;
        listbox.innerHTML = '';
        input.setAttribute('aria-expanded', 'false');
        input.removeAttribute('aria-activedescendant');
        currentResults = [];
        activeIndex = -1;
      };

      const setActive = (idx: number) => {
        activeIndex = idx;
        const items = listbox.querySelectorAll<HTMLLIElement>('.ec-ac-option');
        items.forEach((el, i) => {
          const active = i === idx;
          el.setAttribute('aria-selected', active ? 'true' : 'false');
          el.classList.toggle('is-active', active);
          if (active) {
            input.setAttribute('aria-activedescendant', el.id);
            const elTop = el.offsetTop;
            const elBottom = elTop + el.offsetHeight;
            if (elTop < listbox.scrollTop) listbox.scrollTop = elTop;
            else if (elBottom > listbox.scrollTop + listbox.clientHeight) {
              listbox.scrollTop = elBottom - listbox.clientHeight;
            }
          }
        });
        if (idx < 0) input.removeAttribute('aria-activedescendant');
      };

      const renderResults = (results: T[], q: string) => {
        currentResults = results;
        activeIndex = -1;
        if (results.length === 0) {
          listbox.innerHTML = `<li class="ec-ac-empty" role="presentation">No matches for “${escapeHtml(q)}”.</li>`;
          listbox.hidden = false;
          input.setAttribute('aria-expanded', 'true');
          return;
        }
        listbox.innerHTML = results
          .map((a, i) => `
            <li class="ec-ac-option" id="${listboxId}-opt-${i}" role="option" aria-selected="false" data-index="${i}">
              ${cfg.renderOption(a)}
            </li>
          `)
          .join('');
        listbox.hidden = false;
        input.setAttribute('aria-expanded', 'true');
      };

      const selectResult = (a: T) => {
        input.value = cfg.formatSelected(a);
        input.readOnly = true;
        input.classList.add('is-selected');
        clearBtn.hidden = false;
        closeList();
        cfg.onSelect(a);
      };

      const clearSelection = () => {
        input.value = '';
        input.readOnly = false;
        input.classList.remove('is-selected');
        clearBtn.hidden = true;
        closeList();
        cfg.onClear();
        input.focus();
      };

      let searchToken = 0;
      input.addEventListener('input', async () => {
        if (input.readOnly) return;
        const q = input.value;
        if (q.trim().length < MIN_CHARS) { closeList(); return; }
        const token = ++searchToken;
        const items = await cfg.loader();
        if (token !== searchToken) return;
        renderResults(searchItems(items, q), q);
      });

      input.addEventListener('focus', () => {
        if (input.readOnly) return;
        const q = input.value;
        if (q.trim().length >= MIN_CHARS && listbox.hidden) {
          cfg.loader().then((items) => {
            if (document.activeElement !== input) return;
            renderResults(searchItems(items, q), q);
          });
        }
        cfg.loader(); // prefetch
      });

      input.addEventListener('keydown', (e) => {
        if (input.readOnly) {
          if (e.key === 'Backspace' || e.key === 'Delete') {
            e.preventDefault();
            clearSelection();
          }
          return;
        }
        switch (e.key) {
          case 'ArrowDown':
            e.preventDefault();
            if (listbox.hidden) {
              const q = input.value;
              if (q.trim().length >= MIN_CHARS) {
                cfg.loader().then((items) => {
                  renderResults(searchItems(items, q), q);
                  if (currentResults.length > 0) setActive(0);
                });
              }
              return;
            }
            if (currentResults.length === 0) return;
            setActive((activeIndex + 1) % currentResults.length);
            break;
          case 'ArrowUp':
            e.preventDefault();
            if (listbox.hidden || currentResults.length === 0) return;
            setActive(activeIndex <= 0 ? currentResults.length - 1 : activeIndex - 1);
            break;
          case 'Enter':
            if (!listbox.hidden && activeIndex >= 0 && currentResults[activeIndex]) {
              e.preventDefault();
              selectResult(currentResults[activeIndex]);
            }
            break;
          case 'Escape':
            if (!listbox.hidden) { e.preventDefault(); closeList(); }
            break;
          case 'Tab':
            closeList();
            break;
        }
      });

      listbox.addEventListener('mousedown', (e) => e.preventDefault());
      listbox.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest<HTMLLIElement>('.ec-ac-option');
        if (!target) return;
        const idx = Number(target.dataset.index);
        const a = currentResults[idx];
        if (a) selectResult(a);
      });
      listbox.addEventListener('mousemove', (e) => {
        const target = (e.target as HTMLElement).closest<HTMLLIElement>('.ec-ac-option');
        if (!target) return;
        const idx = Number(target.dataset.index);
        if (!Number.isNaN(idx) && idx !== activeIndex) setActive(idx);
      });
      clearBtn.addEventListener('click', clearSelection);

      document.addEventListener('click', (e) => {
        if (!cfg.wrap.contains(e.target as Node)) closeList();
      });
    }

    // ---------- Renderers for option rows ----------
    const renderAirportOption = (a: Airport) => {
      const country = countryDisplay(a.country);
      const location = [a.city, country].filter(Boolean).join(', ');
      return `
        <span class="ec-ac-opt-name">${escapeHtml(a.name)} <span class="ec-ac-opt-iata">(${escapeHtml(a.iata)})</span></span>
        <span class="ec-ac-opt-loc">${escapeHtml(location)}</span>
      `;
    };
    const renderAirlineOption = (a: Airline) => {
      const iata = escapeHtml(a.iata);
      const country = escapeHtml(a.country);
      return `
        <span class="ec-ac-opt-name">${escapeHtml(a.name)}</span>
        <span class="ec-ac-opt-loc"><span class="ec-ac-opt-iata">${iata}</span>${country ? ' · ' + country : ''}</span>
      `;
    };
    const formatSelected = (a: { iata: string; name: string }) => `${a.name} (${a.iata})`;

    // ---------- Step 1: airports ----------
    wireAutocomplete<Airport>({
      wrap: root.querySelector<HTMLElement>('.ec-ac[data-field="origin"]')!,
      loader: loadAirports,
      formatSelected,
      renderOption: renderAirportOption,
      onSelect: (a) => { state.origin = a; refreshUi(); },
      onClear: () => { state.origin = null; refreshUi(); },
    });
    wireAutocomplete<Airport>({
      wrap: root.querySelector<HTMLElement>('.ec-ac[data-field="destination"]')!,
      loader: loadAirports,
      formatSelected,
      renderOption: renderAirportOption,
      onSelect: (a) => { state.destination = a; refreshUi(); },
      onClear: () => { state.destination = null; refreshUi(); },
    });

    // ---------- Step 2: airline ----------
    wireAutocomplete<Airline>({
      wrap: root.querySelector<HTMLElement>('.ec-ac[data-field="airline"]')!,
      loader: loadAirlines,
      formatSelected,
      renderOption: renderAirlineOption,
      onSelect: (a) => { state.airline = a; refreshUi(); },
      onClear: () => { state.airline = null; refreshUi(); },
    });

    // ---------- Step 3: date ----------
    const dateInput = root.querySelector<HTMLInputElement>('#ec-date')!;
    const todayIso = new Date().toISOString().slice(0, 10);
    const threeYearsAgo = new Date();
    threeYearsAgo.setFullYear(threeYearsAgo.getFullYear() - 3);
    dateInput.min = threeYearsAgo.toISOString().slice(0, 10);
    dateInput.max = todayIso;
    dateInput.addEventListener('input', () => {
      const v = dateInput.value;
      state.flightDate = v && v >= dateInput.min && v <= dateInput.max ? v : null;
      refreshUi();
    });

    // ---------- Generic radiogroup helper (Steps 4-6) ----------
    type RadioController = {
      setValue: (value: string | null) => void;
      revalidate: () => void;
    };

    function wireRadioGroup(
      container: HTMLElement,
      onSelect: (value: string | null) => void,
    ): RadioController {
      const all = () => Array.from(
        container.querySelectorAll<HTMLButtonElement>('[role="radio"]'),
      );
      const visible = () => all().filter((el) => !el.hidden);

      const applyTabIndex = (selected: HTMLButtonElement | null) => {
        const vis = visible();
        // One tab stop per group: the selected option if present, otherwise the first visible option.
        const tabbable = selected && !selected.hidden ? selected : vis[0];
        all().forEach((el) => {
          if (el.hidden) {
            el.setAttribute('tabindex', '-1');
          } else {
            el.setAttribute('tabindex', el === tabbable ? '0' : '-1');
          }
        });
      };

      const select = (el: HTMLButtonElement | null, focus = false) => {
        all().forEach((b) => {
          b.setAttribute('aria-checked', 'false');
          b.classList.remove('is-selected');
        });
        if (el && !el.hidden) {
          el.setAttribute('aria-checked', 'true');
          el.classList.add('is-selected');
          applyTabIndex(el);
          if (focus) el.focus();
          onSelect(el.dataset.value ?? null);
        } else {
          applyTabIndex(null);
          onSelect(null);
        }
      };

      all().forEach((el) => {
        el.addEventListener('click', () => {
          if (!el.hidden) select(el);
        });
        el.addEventListener('keydown', (e) => {
          const vis = visible();
          const idx = vis.indexOf(el);
          if (idx < 0) return;
          switch (e.key) {
            case 'ArrowRight':
            case 'ArrowDown':
              e.preventDefault();
              select(vis[(idx + 1) % vis.length], true);
              break;
            case 'ArrowLeft':
            case 'ArrowUp':
              e.preventDefault();
              select(vis[(idx - 1 + vis.length) % vis.length], true);
              break;
            case ' ':
            case 'Enter':
              e.preventDefault();
              select(el);
              break;
          }
        });
      });

      // Initial state: nothing selected, first visible option is tabbable.
      applyTabIndex(null);

      return {
        setValue(value) {
          if (!value) return select(null);
          const target = all().find((b) => b.dataset.value === value && !b.hidden);
          select(target ?? null);
        },
        revalidate() {
          const sel = all().find((b) => b.classList.contains('is-selected'));
          if (sel && sel.hidden) {
            // The selected option became hidden — drop selection.
            select(null);
          } else {
            applyTabIndex(sel ?? null);
          }
        },
      };
    }

    // ---------- Wire every radiogroup on the page ----------
    const radioGroups: Record<string, RadioController> = {};
    root.querySelectorAll<HTMLElement>('[data-radio-name]').forEach((group) => {
      const name = group.dataset.radioName!;
      radioGroups[name] = wireRadioGroup(group, (value) => {
        handleRadioChange(name, value);
      });
    });

    const STEP5_FIELDS = [
      'delayDuration',
      'notificationTiming',
      'reroutingOffered',
      'deniedBoardingType',
      'originalClass',
      'actualClass',
    ] as const;

    function clearStep5State() {
      state.delayDuration = null;
      state.notificationTiming = null;
      state.reroutingOffered = null;
      state.deniedBoardingType = null;
      state.originalClass = null;
      state.actualClass = null;
      STEP5_FIELDS.forEach((name) => radioGroups[name]?.setValue(null));
      resetActualClassVisibility();
    }

    function updateActualClassVisibility() {
      const group = root.querySelector<HTMLElement>('[data-radio-name="actualClass"]');
      if (!group) return;
      const origRank = state.originalClass
        ? CABIN_CLASS_ORDER.indexOf(state.originalClass)
        : -1;
      group.querySelectorAll<HTMLButtonElement>('[role="radio"]').forEach((el) => {
        const val = el.dataset.value as CabinClass;
        const valRank = CABIN_CLASS_ORDER.indexOf(val);
        // Hide options that aren't strictly lower than the original class.
        // When no original class is chosen, show all (actual-class options never include "first").
        el.hidden = origRank !== -1 && valRank <= origRank;
      });
      // If the current actualClass became hidden, drop it.
      if (state.actualClass) {
        const selectedEl = group.querySelector<HTMLButtonElement>(
          `[role="radio"][data-value="${state.actualClass}"]`,
        );
        if (selectedEl?.hidden) {
          state.actualClass = null;
        }
      }
      radioGroups['actualClass']?.revalidate();
    }

    function resetActualClassVisibility() {
      const group = root.querySelector<HTMLElement>('[data-radio-name="actualClass"]');
      if (!group) return;
      // Show every actualClass option (actualClass options never include "first" in the markup).
      group.querySelectorAll<HTMLButtonElement>('[role="radio"]').forEach((el) => {
        el.hidden = false;
      });
      radioGroups['actualClass']?.revalidate();
    }

    function handleRadioChange(name: string, value: string | null) {
      switch (name) {
        case 'issueType': {
          const newVal = value as IssueType | null;
          if (newVal !== state.issueType) {
            clearStep5State();
          }
          state.issueType = newVal;
          break;
        }
        case 'delayDuration':
          state.delayDuration = value as DelayDuration | null;
          break;
        case 'notificationTiming':
          state.notificationTiming = value as NotificationTiming | null;
          break;
        case 'reroutingOffered':
          state.reroutingOffered = value as ReroutingOffered | null;
          break;
        case 'deniedBoardingType':
          state.deniedBoardingType = value as DeniedBoardingType | null;
          break;
        case 'originalClass':
          state.originalClass = value as CabinClass | null;
          updateActualClassVisibility();
          break;
        case 'actualClass':
          state.actualClass = value as CabinClass | null;
          break;
        case 'disruptionReason':
          state.disruptionReason = value as DisruptionReason | null;
          break;
      }
      refreshUi();
    }

    // ---------- Nav buttons ----------
    root.querySelectorAll<HTMLButtonElement>('.ec-next-btn').forEach((btn) => {
      btn.addEventListener('click', () => nextStep());
    });
    root.querySelectorAll<HTMLButtonElement>('.ec-back-btn').forEach((btn) => {
      btn.addEventListener('click', () => prevStep());
    });

    // ---------- Step state machine ----------
    const isStepValid = (step: number): boolean => {
      switch (step) {
        case 1:
          return !!(state.origin && state.destination && state.origin.iata !== state.destination.iata);
        case 2:
          return !!state.airline;
        case 3:
          return !!state.flightDate;
        case 4:
          return !!state.issueType;
        case 5:
          switch (state.issueType) {
            case 'delayed':
              return !!state.delayDuration;
            case 'cancelled':
              return !!(state.notificationTiming && state.reroutingOffered);
            case 'denied_boarding':
              return !!state.deniedBoardingType;
            case 'downgraded':
              return !!(state.originalClass && state.actualClass);
            default:
              return false;
          }
        case 6:
          // Downgrade cases don't need a reason (EU261 Article 10 — no exempting defense).
          if (state.issueType === 'downgraded') return true;
          return !!state.disruptionReason;
        default:
          return false;
      }
    };

    const nextStep = () => {
      if (currentStep === 'result') return;
      if (!isStepValid(currentStep)) return;
      if (currentStep >= LAST_IMPLEMENTED_STEP) {
        const input = {
          origin: state.origin,
          destination: state.destination,
          airline: state.airline,
          flightDate: state.flightDate,
          issueType: state.issueType,
          delayDuration: state.delayDuration,
          notificationTiming: state.notificationTiming,
          reroutingOffered: state.reroutingOffered,
          deniedBoardingType: state.deniedBoardingType,
          originalClass: state.originalClass,
          actualClass: state.actualClass,
          disruptionReason: state.disruptionReason,
        };
        const result = evaluateEligibility(input) as EligibilityResult;
        console.log('[EligibilityChecker] Judgment result:', result);
        state.result = result;
        currentStep = 'result';
        renderStep();
        return;
      }
      currentStep += 1;
      renderStep();
    };
    const prevStep = () => {
      if (currentStep === 'result' || currentStep <= 1) return;
      currentStep -= 1;
      renderStep();
    };

    const renderStep = () => {
      root.dataset.step = String(currentStep);
      root.querySelectorAll<HTMLElement>('.ec-step').forEach((el) => {
        el.classList.toggle('is-active', Number(el.dataset.stepId) === currentStep);
      });

      // Result step — populate the outcome view, skip numeric-step plumbing.
      if (currentStep === 'result') {
        if (state.result) renderResult(state.result);
        return;
      }

      const label = root.querySelector<HTMLElement>('.ec-progress-current');
      if (label) label.textContent = String(currentStep);
      const fill = root.querySelector<HTMLElement>('.ec-progress-fill');
      if (fill) fill.style.width = `${(currentStep / TOTAL_STEPS) * 100}%`;

      // Step 5 branch visibility (driven by state.issueType).
      const step5 = root.querySelector<HTMLElement>('.ec-step[data-step-id="5"]');
      if (step5) {
        step5.querySelectorAll<HTMLElement>('.ec-branch').forEach((branch) => {
          branch.classList.toggle(
            'is-active',
            branch.dataset.branch === state.issueType,
          );
        });
      }

      // Step 6 variant visibility — downgrades skip the reason selector.
      const step6 = root.querySelector<HTMLElement>('.ec-step[data-step-id="6"]');
      if (step6) {
        const variant = state.issueType === 'downgraded' ? 'downgraded' : 'default';
        step6.querySelectorAll<HTMLElement>('.ec-step6-variant').forEach((el) => {
          el.classList.toggle('is-active', el.dataset.variant === variant);
        });
      }

      // Auto-collapse the scope notice on every step change so each step starts clean.
      const scopeDetails = root.querySelector<HTMLDetailsElement>('.ec-scope-details');
      if (scopeDetails) scopeDetails.open = false;

      // Focus the first meaningful input of the new step, skipping animation-gated paint.
      requestAnimationFrame(() => {
        const active = root.querySelector<HTMLElement>('.ec-step.is-active');
        if (!active) return;
        const activeBranch = active.querySelector<HTMLElement>('.ec-branch.is-active') ?? active;
        const focusTarget =
          activeBranch.querySelector<HTMLElement>('.ec-ac-input:not([readonly])') ||
          activeBranch.querySelector<HTMLElement>('.ec-date-input') ||
          activeBranch.querySelector<HTMLElement>('[role="radio"][aria-checked="true"]:not([hidden])') ||
          activeBranch.querySelector<HTMLElement>('[role="radio"]:not([hidden])');
        focusTarget?.focus({ preventScroll: true });
      });
    };

    // ---------- Result view ----------
    const formatCompensation = (comp: CoverageEntry['compensation']): string => {
      if (!comp) return '—';
      switch (comp.type) {
        case 'fixed':
          return `${comp.currency ?? ''} ${(comp.amount ?? 0).toLocaleString('en-US')}`.trim();
        case 'range':
          return `${comp.currency ?? ''} ${(comp.min ?? 0).toLocaleString('en-US')}\u2013${(comp.max ?? 0).toLocaleString('en-US')}`.trim();
        case 'percentage':
          return `${comp.value ?? 0}% refund`;
        case 'actual_damages':
          return 'Actual damages';
        case 'assistance + court_damages':
          return comp.typicalCourt ? `Assistance + ${comp.typicalCourt}` : 'Assistance + possible damages';
        case 'assistance_only':
          return 'Assistance only';
        case 'refund_difference':
          return `${comp.currency ?? ''} fare-difference refund`.trim();
        default:
          return '—';
      }
    };

    const renderCoverageCard = (entry: CoverageEntry): string => `
      <article class="ec-coverage-card">
        <div class="ec-coverage-header">
          <span class="ec-coverage-name">${escapeHtml(entry.regulation)}</span>
          <span class="ec-coverage-amount">${escapeHtml(formatCompensation(entry.compensation))}</span>
        </div>
        <p class="ec-coverage-reason">${escapeHtml(entry.reasoning)}</p>
      </article>
    `;

    const renderDetailsBody = (result: EligibilityResult): string => {
      const parts: string[] = [];
      if (result.notCoveredBy?.length) {
        parts.push(`
          <div class="ec-not-covered">
            <h4>Not covered by</h4>
            <ul>
              ${result.notCoveredBy
                .map((r) => `<li><strong>${escapeHtml(r.regulation)}</strong>: ${escapeHtml(r.reasoning)}</li>`)
                .join('')}
            </ul>
          </div>
        `);
      }
      if (result.notes?.length) {
        parts.push(`
          <div class="ec-notes">
            <h4>Additional notes</h4>
            <ul>
              ${result.notes.map((n) => `<li>${escapeHtml(n)}</li>`).join('')}
            </ul>
          </div>
        `);
      }
      return parts.join('');
    };

    const renderOOSAlternatives = (result: EligibilityResult): string => {
      const reason = (result.outOfScopeReason ?? '').toLowerCase();
      if (reason.includes('us domestic') || reason.includes('dot')) {
        return [
          '<li>File a complaint with the <a href="https://secure.dot.gov/air-travel-complaint" rel="noopener" target="_blank">US DOT Aviation Consumer Protection</a>.</li>',
          '<li>Check your airline\u2019s Customer Service Plan for voluntary compensation.</li>',
          '<li>Review your travel insurance for delay or cancellation coverage.</li>',
        ].join('');
      }
      return [
        '<li>Review the airline\u2019s contract of carriage for voluntary compensation.</li>',
        '<li>Contact your local consumer-protection authority or aviation regulator.</li>',
        '<li>Check your travel insurance for delay or cancellation coverage.</li>',
      ].join('');
    };

    const buildFlightSummary = (result: EligibilityResult): string => {
      if (!state.origin || !state.destination || !state.airline) return '';
      return (
        `Based on your flight from <strong>${escapeHtml(state.origin.city)} (${escapeHtml(state.origin.iata)})</strong> ` +
        `to <strong>${escapeHtml(state.destination.city)} (${escapeHtml(state.destination.iata)})</strong> ` +
        `on ${escapeHtml(state.airline.name)} \u2014 ${result.distance.toLocaleString('en-US')} km.`
      );
    };

    const renderResult = (result: EligibilityResult) => {
      const container = root.querySelector<HTMLElement>('.ec-result');
      if (!container) return;
      const variantName = result.outOfScope
        ? 'out_of_scope'
        : result.eligible
          ? 'eligible'
          : 'not_eligible';

      container.querySelectorAll<HTMLElement>('.ec-result-variant').forEach((v) => {
        v.classList.toggle('is-active', v.dataset.variant === variantName);
      });
      const active = container.querySelector<HTMLElement>(
        `.ec-result-variant[data-variant="${variantName}"]`,
      );
      if (!active) return;

      const summarySlot = active.querySelector<HTMLElement>('[data-slot="verdict-summary"]');
      if (summarySlot) {
        if (variantName === 'out_of_scope') {
          summarySlot.textContent = result.outOfScopeReason ?? '';
        } else {
          summarySlot.innerHTML = buildFlightSummary(result);
        }
      }

      if (variantName === 'eligible') {
        const grid = active.querySelector<HTMLElement>('[data-slot="coverage-grid"]');
        if (grid) grid.innerHTML = result.coverage.map(renderCoverageCard).join('');
        const details = active.querySelector<HTMLElement>('[data-slot="details-body"]');
        if (details) details.innerHTML = renderDetailsBody(result);
        // Reset the accordion each time the result screen is shown.
        const accordion = active.querySelector<HTMLDetailsElement>('.ec-details');
        if (accordion) accordion.open = false;
      } else if (variantName === 'not_eligible') {
        const list = active.querySelector<HTMLElement>('[data-slot="reason-list"]');
        if (list) {
          list.innerHTML = result.notCoveredBy
            .map((r) => `<li><strong>${escapeHtml(r.regulation)}</strong>: ${escapeHtml(r.reasoning)}</li>`)
            .join('');
        }
      } else if (variantName === 'out_of_scope') {
        const altList = active.querySelector<HTMLElement>('[data-slot="alt-list"]');
        if (altList) altList.innerHTML = renderOOSAlternatives(result);
      }

      // Scroll the widget to the top of the viewport so the verdict is what the
      // user sees first — without this, they land wherever the Step 6 form left the
      // scroll position. Then focus the restart button so keyboard users can
      // easily start over without tabbing through the entire result view.
      requestAnimationFrame(() => {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        root.scrollIntoView({
          behavior: prefersReduced ? 'auto' : 'smooth',
          block: 'start',
        });
        const restart = active.querySelector<HTMLButtonElement>('.ec-restart-btn');
        restart?.focus({ preventScroll: true });
      });
    };

    const startOver = () => {
      // Reset state
      state.origin = null;
      state.destination = null;
      state.airline = null;
      state.flightDate = null;
      state.issueType = null;
      state.delayDuration = null;
      state.notificationTiming = null;
      state.reroutingOffered = null;
      state.deniedBoardingType = null;
      state.originalClass = null;
      state.actualClass = null;
      state.disruptionReason = null;
      state.result = null;

      // Clear autocomplete inputs
      root.querySelectorAll<HTMLInputElement>('.ec-ac-input').forEach((input) => {
        input.value = '';
        input.readOnly = false;
        input.classList.remove('is-selected');
      });
      root.querySelectorAll<HTMLButtonElement>('.ec-ac-clear').forEach((btn) => {
        btn.hidden = true;
      });

      // Clear date input
      const dateInput = root.querySelector<HTMLInputElement>('#ec-date');
      if (dateInput) dateInput.value = '';

      // Reset every radio group (Step 4 issue type + all Step 5 branches + Step 6 reason).
      Object.values(radioGroups).forEach((ctl) => ctl.setValue(null));
      resetActualClassVisibility();

      // Back to Step 1.
      currentStep = 1;
      renderStep();
      refreshUi();
    };

    // Wire restart buttons (one per result variant).
    root.querySelectorAll<HTMLButtonElement>('.ec-restart-btn').forEach((btn) => {
      btn.addEventListener('click', startOver);
    });

    const refreshUi = () => {
      // Next buttons per step
      root.querySelectorAll<HTMLElement>('.ec-step').forEach((stepEl) => {
        const stepNum = Number(stepEl.dataset.stepId);
        const nextBtn = stepEl.querySelector<HTMLButtonElement>('.ec-next-btn');
        if (nextBtn) nextBtn.disabled = !isStepValid(stepNum);
      });
      // Same-airport warning (Step 1)
      const warning = root.querySelector<HTMLElement>('#ec-warning');
      if (warning) {
        const bothSelected = !!(state.origin && state.destination);
        const sameAirport = bothSelected && state.origin!.iata === state.destination!.iata;
        warning.classList.toggle('is-visible', sameAirport);
      }
    };

    // ---------- Initial render ----------
    renderStep();
    refreshUi();

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }
  }
</script>

