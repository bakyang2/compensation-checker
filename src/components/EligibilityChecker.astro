---
// EligibilityChecker.astro — multi-step flight compensation eligibility widget.
// Step 1-5-B: Steps 1 (airports), 2 (airline), 3 (flight date), 4 (issue type).
// Total flow is 6 steps; steps 5-6 come in Step 1-5-C.
---

<div
  class="ec checker-shell"
  id="eligibility-checker"
  data-step="1"
  aria-live="polite"
>
  <!-- Progress indicator -->
  <div class="ec-progress" aria-hidden="true">
    <span class="ec-progress-label">
      Step <span class="ec-progress-current">1</span> of 6
    </span>
    <div class="ec-progress-bar">
      <div class="ec-progress-fill"></div>
    </div>
  </div>

  <!-- ================================================= -->
  <!-- STEP 1 — Origin / Destination                     -->
  <!-- ================================================= -->
  <section
    class="ec-step is-active"
    data-step-id="1"
    aria-labelledby="ec-step1-title"
  >
    <header class="ec-step-head">
      <span class="ec-step-counter">Step 1</span>
      <h3 id="ec-step1-title" class="ec-step-title">Where did you fly?</h3>
      <p class="ec-step-sub">Enter your departure and arrival airports.</p>
    </header>

    <div class="ec-fields">
      <div class="ec-field">
        <label class="ec-label" for="ec-origin">From</label>
        <div
          class="ec-ac"
          data-field="origin"
          data-kind="airport"
        >
          <div class="ec-ac-inputwrap">
            <svg
              class="ec-ac-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
            </svg>
            <input
              type="text"
              id="ec-origin"
              class="ec-ac-input"
              placeholder="e.g. LHR, Heathrow, or Paris"
              role="combobox"
              aria-autocomplete="list"
              aria-expanded="false"
              aria-controls="ec-origin-listbox"
              autocomplete="off"
              spellcheck="false"
            />
            <button type="button" class="ec-ac-clear" aria-label="Clear origin" hidden>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
          <ul class="ec-ac-list" id="ec-origin-listbox" role="listbox" aria-label="Origin airport suggestions" hidden></ul>
        </div>
      </div>

      <div class="ec-field">
        <label class="ec-label" for="ec-destination">To</label>
        <div
          class="ec-ac"
          data-field="destination"
          data-kind="airport"
        >
          <div class="ec-ac-inputwrap">
            <svg
              class="ec-ac-icon ec-ac-icon-flip"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
            </svg>
            <input
              type="text"
              id="ec-destination"
              class="ec-ac-input"
              placeholder="e.g. CDG, Madrid, or Rome"
              role="combobox"
              aria-autocomplete="list"
              aria-expanded="false"
              aria-controls="ec-destination-listbox"
              autocomplete="off"
              spellcheck="false"
            />
            <button type="button" class="ec-ac-clear" aria-label="Clear destination" hidden>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
          <ul class="ec-ac-list" id="ec-destination-listbox" role="listbox" aria-label="Destination airport suggestions" hidden></ul>
        </div>
      </div>
    </div>

    <p class="ec-warning" id="ec-warning" role="status" aria-live="polite">
      Origin and destination must be different airports.
    </p>

    <div class="ec-nav">
      <button type="button" class="ec-next-btn" data-action="next" disabled>
        Next
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </div>
  </section>

  <!-- ================================================= -->
  <!-- STEP 2 — Airline                                  -->
  <!-- ================================================= -->
  <section
    class="ec-step"
    data-step-id="2"
    aria-labelledby="ec-step2-title"
  >
    <header class="ec-step-head">
      <span class="ec-step-counter">Step 2</span>
      <h3 id="ec-step2-title" class="ec-step-title">Which airline operated the flight?</h3>
      <p class="ec-step-sub">Pick the carrier on your ticket.</p>
    </header>

    <div class="ec-field">
      <label class="ec-label" for="ec-airline">Airline</label>
      <p class="ec-hint">Your airline determines whether EU261 applies to your flight.</p>
      <div
        class="ec-ac"
        data-field="airline"
        data-kind="airline"
      >
        <div class="ec-ac-inputwrap">
          <svg
            class="ec-ac-icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
          </svg>
          <input
            type="text"
            id="ec-airline"
            class="ec-ac-input"
            placeholder="e.g. Lufthansa, British Airways, Ryanair"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="ec-airline-listbox"
            autocomplete="off"
            spellcheck="false"
          />
          <button type="button" class="ec-ac-clear" aria-label="Clear airline" hidden>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <ul class="ec-ac-list" id="ec-airline-listbox" role="listbox" aria-label="Airline suggestions" hidden></ul>
      </div>
    </div>

    <div class="ec-nav">
      <button type="button" class="ec-back-btn" data-action="back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5"/>
          <path d="m12 19-7-7 7-7"/>
        </svg>
        Back
      </button>
      <button type="button" class="ec-next-btn" data-action="next" disabled>
        Next
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </div>
  </section>

  <!-- ================================================= -->
  <!-- STEP 3 — Flight date                              -->
  <!-- ================================================= -->
  <section
    class="ec-step"
    data-step-id="3"
    aria-labelledby="ec-step3-title"
  >
    <header class="ec-step-head">
      <span class="ec-step-counter">Step 3</span>
      <h3 id="ec-step3-title" class="ec-step-title">When did you fly?</h3>
      <p class="ec-step-sub">The flight date determines which regulations apply.</p>
    </header>

    <div class="ec-field">
      <label class="ec-label" for="ec-date">Flight date</label>
      <p class="ec-hint">When was your flight scheduled to depart? (You can claim for flights up to 3 years ago.)</p>
      <p class="ec-hint-format">Format: Year · Month · Day (your browser may display this in your system language).</p>
      <input
        type="date"
        id="ec-date"
        class="ec-date-input"
      />
    </div>

    <div class="ec-nav">
      <button type="button" class="ec-back-btn" data-action="back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5"/>
          <path d="m12 19-7-7 7-7"/>
        </svg>
        Back
      </button>
      <button type="button" class="ec-next-btn" data-action="next" disabled>
        Next
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </div>
  </section>

  <!-- ================================================= -->
  <!-- STEP 4 — Issue type                               -->
  <!-- ================================================= -->
  <section
    class="ec-step"
    data-step-id="4"
    aria-labelledby="ec-step4-title"
  >
    <header class="ec-step-head">
      <span class="ec-step-counter">Step 4</span>
      <h3 id="ec-step4-title" class="ec-step-title">What happened to your flight?</h3>
      <p class="ec-step-sub">Select the scenario that applies.</p>
    </header>

    <div
      class="ec-issue-grid"
      role="radiogroup"
      aria-labelledby="ec-step4-title"
      data-radio-name="issueType"
    >
      <button
        type="button"
        role="radio"
        aria-checked="false"
        tabindex="0"
        class="ec-issue-option"
        data-value="delayed"
      >
        <span class="ec-issue-icon" aria-hidden="true">⏱</span>
        <span class="ec-issue-title">Delayed</span>
        <span class="ec-issue-desc">My flight arrived late (based on arrival time, not departure).</span>
      </button>

      <button
        type="button"
        role="radio"
        aria-checked="false"
        tabindex="-1"
        class="ec-issue-option"
        data-value="cancelled"
      >
        <span class="ec-issue-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </span>
        <span class="ec-issue-title">Cancelled</span>
        <span class="ec-issue-desc">My flight was cancelled.</span>
      </button>

      <button
        type="button"
        role="radio"
        aria-checked="false"
        tabindex="-1"
        class="ec-issue-option"
        data-value="denied_boarding"
      >
        <span class="ec-issue-icon" aria-hidden="true">🚫</span>
        <span class="ec-issue-title">Denied boarding</span>
        <span class="ec-issue-desc">I was bumped due to overbooking.</span>
      </button>

      <button
        type="button"
        role="radio"
        aria-checked="false"
        tabindex="-1"
        class="ec-issue-option"
        data-value="downgraded"
      >
        <span class="ec-issue-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <polyline points="19 12 12 19 5 12"/>
          </svg>
        </span>
        <span class="ec-issue-title">Downgraded</span>
        <span class="ec-issue-desc">My seat was downgraded to a lower class.</span>
      </button>
    </div>

    <div class="ec-issue-note" role="note">
      <svg class="ec-issue-note-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="16" x2="12" y2="12"/>
        <line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
      <span>Compensation for delays is based on your <strong>arrival time</strong>, not departure. A flight that leaves late but arrives on time isn't eligible. The 3-hour threshold under EU261/UK261 refers to how late you arrived at your final destination.</span>
    </div>

    <div class="ec-nav">
      <button type="button" class="ec-back-btn" data-action="back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5"/>
          <path d="m12 19-7-7 7-7"/>
        </svg>
        Back
      </button>
      <button type="button" class="ec-next-btn" data-action="next" disabled>
        Next
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </div>
  </section>

  <!-- ================================================= -->
  <!-- STEP 5 — Issue-specific follow-up (branched)      -->
  <!-- ================================================= -->
  <section
    class="ec-step"
    data-step-id="5"
    aria-labelledby="ec-step5-title"
  >
    <header class="ec-step-head">
      <span class="ec-step-counter">Step 5</span>
      <h3 id="ec-step5-title" class="ec-step-title">Tell us more</h3>
      <p class="ec-step-sub">A few details specific to what happened on your flight.</p>
    </header>

    <!-- Branch A: delayed -->
    <div class="ec-branch" data-branch="delayed">
      <div class="ec-branch-question">
        <h4 class="ec-branch-question-title">How much was your arrival delayed?</h4>
        <p class="ec-branch-question-hint">This is the delay at your final destination, not the departure delay.</p>
        <div
          class="ec-choice-group"
          role="radiogroup"
          aria-label="Arrival delay duration"
          data-radio-name="delayDuration"
        >
          <button type="button" role="radio" aria-checked="false" tabindex="0" class="ec-choice-option" data-value="under_2h">
            <span class="ec-choice-title">Less than 2 hours</span>
            <span class="ec-choice-subtitle">Usually not eligible for compensation.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="2_to_3h">
            <span class="ec-choice-title">2 to under 3 hours</span>
            <span class="ec-choice-subtitle">Limited compensation under some laws.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="3_to_4h">
            <span class="ec-choice-title">3 to under 4 hours</span>
            <span class="ec-choice-subtitle">EU261 / UK261 / APPR threshold.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="4h_plus">
            <span class="ec-choice-title">4 hours or more</span>
            <span class="ec-choice-subtitle">Higher compensation tier.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="never_arrived">
            <span class="ec-choice-title">I never arrived (flight cancelled mid-journey)</span>
            <span class="ec-choice-subtitle">Treated as a cancellation.</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Branch B: cancelled -->
    <div class="ec-branch" data-branch="cancelled">
      <div class="ec-branch-question">
        <h4 class="ec-branch-question-title">When did the airline notify you of the cancellation?</h4>
        <p class="ec-branch-question-hint">Compensation depends heavily on how much notice you received.</p>
        <div
          class="ec-choice-group"
          role="radiogroup"
          aria-label="Notification timing"
          data-radio-name="notificationTiming"
        >
          <button type="button" role="radio" aria-checked="false" tabindex="0" class="ec-choice-option" data-value="under_7d">
            <span class="ec-choice-title">Less than 7 days before</span>
            <span class="ec-choice-subtitle">Strongest case for compensation.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="7_to_13d">
            <span class="ec-choice-title">7 to 13 days before</span>
            <span class="ec-choice-subtitle">Conditional — depends on rerouting.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="14d_plus">
            <span class="ec-choice-title">14 days or more before</span>
            <span class="ec-choice-subtitle">Usually not eligible for compensation.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="at_airport">
            <span class="ec-choice-title">Only at the airport / during travel</span>
            <span class="ec-choice-subtitle">Treated as same-day cancellation.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="unknown">
            <span class="ec-choice-title">I don't remember</span>
            <span class="ec-choice-subtitle">We'll check conservatively.</span>
          </button>
        </div>
      </div>

      <div class="ec-branch-question">
        <h4 class="ec-branch-question-title">Did the airline offer alternative transportation?</h4>
        <p class="ec-branch-question-hint">Rerouting options affect your eligibility in some jurisdictions.</p>
        <div
          class="ec-choice-group is-single-col"
          role="radiogroup"
          aria-label="Rerouting offer"
          data-radio-name="reroutingOffered"
        >
          <button type="button" role="radio" aria-checked="false" tabindex="0" class="ec-choice-option" data-value="yes_accepted">
            <span class="ec-choice-title">Yes, and I accepted it</span>
            <span class="ec-choice-subtitle">Arrival delay determines compensation.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="yes_declined">
            <span class="ec-choice-title">Yes, but I declined / took a refund</span>
            <span class="ec-choice-subtitle">Refund only, usually no compensation.</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="not_offered">
            <span class="ec-choice-title">No rerouting offered</span>
            <span class="ec-choice-subtitle">Stronger case for full compensation.</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Branch C: denied_boarding -->
    <div class="ec-branch" data-branch="denied_boarding">
      <div class="ec-branch-question">
        <h4 class="ec-branch-question-title">Were you denied boarding voluntarily or involuntarily?</h4>
        <p class="ec-branch-question-hint">This changes your rights significantly.</p>
        <div
          class="ec-choice-group"
          role="radiogroup"
          aria-label="Denied boarding type"
          data-radio-name="deniedBoardingType"
        >
          <button type="button" role="radio" aria-checked="false" tabindex="0" class="ec-choice-option" data-value="involuntary">
            <span class="ec-choice-title">Involuntarily — I was bumped against my will</span>
            <span class="ec-choice-subtitle">Fixed compensation likely applies (EU261 Article 4).</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="voluntary">
            <span class="ec-choice-title">Voluntarily — I accepted the airline's offer to take a later flight</span>
            <span class="ec-choice-subtitle">Based on the terms you agreed to, not fixed compensation.</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Branch D: downgraded -->
    <div class="ec-branch" data-branch="downgraded">
      <div class="ec-branch-question">
        <h4 class="ec-branch-question-title">What class did you originally book?</h4>
        <div
          class="ec-choice-group"
          role="radiogroup"
          aria-label="Original cabin class"
          data-radio-name="originalClass"
        >
          <button type="button" role="radio" aria-checked="false" tabindex="0" class="ec-choice-option" data-value="first">
            <span class="ec-choice-title">First class</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="business">
            <span class="ec-choice-title">Business class</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="premium_economy">
            <span class="ec-choice-title">Premium economy</span>
          </button>
        </div>
      </div>

      <div class="ec-branch-question">
        <h4 class="ec-branch-question-title">What class did you actually fly?</h4>
        <p class="ec-branch-question-hint">Only classes lower than your booked class appear here.</p>
        <div
          class="ec-choice-group"
          role="radiogroup"
          aria-label="Actual cabin class flown"
          data-radio-name="actualClass"
        >
          <button type="button" role="radio" aria-checked="false" tabindex="0" class="ec-choice-option" data-value="business">
            <span class="ec-choice-title">Business class</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="premium_economy">
            <span class="ec-choice-title">Premium economy</span>
          </button>
          <button type="button" role="radio" aria-checked="false" tabindex="-1" class="ec-choice-option" data-value="economy">
            <span class="ec-choice-title">Economy</span>
          </button>
        </div>
      </div>
    </div>

    <div class="ec-nav">
      <button type="button" class="ec-back-btn" data-action="back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5"/>
          <path d="m12 19-7-7 7-7"/>
        </svg>
        Back
      </button>
